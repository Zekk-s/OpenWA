# =====================================================
# OpenWA — avm-02 kalıcı kurulum (.env şablonu)
# Kopyala: cp deploy/avm-02/.env.example .env
# =====================================================

NODE_ENV=production
API_PORT=2785

# --- Admin API anahtarı (ZORUNLU, güvenli sakla) ---
# Üret:  echo "owa_k1_$(openssl rand -hex 32)"
API_MASTER_KEY=owa_k1_CHANGE_ME

# --- Kalıcılık ---
# Reboot sonrası yetkili WhatsApp oturumları otomatik başlar
AUTO_START_SESSIONS=true

# --- Agentic kullanım (MCP) ---
# Agent'lar (Claude, n8n MCP client) http(s)://<domain>/mcp adresine bağlanır
MCP_ENABLED=true
# Read-only güvenli varsayılan. Mesaj gönderme gibi yazma araçları için
# false yap (agent'a master key değil, oturum-kapsamlı OPERATOR anahtarı ver):
MCP_READONLY=true

# --- Reverse proxy entegrasyonu ---
# Traefik/NPM'in bağlı olduğu docker ağının adı (yoksa: docker network create proxy)
PROXY_NETWORK=proxy

# Traefik kullanıyorsan: etiketleri aç ve domain'i yaz
TRAEFIK_ENABLE=false
WA_DOMAIN=wa.zionno.example
TRAEFIK_CERT_RESOLVER=letsencrypt

# Nginx Proxy Manager kullanıyorsan: TRAEFIK_ENABLE=false bırak,
# NPM'de yeni Proxy Host -> forward: openwa-api : 2785 (aynı docker ağı)

# --- Veritabanı ---
# Boş bırak = SQLite (dosya, openwa_openwa-data volume içinde, tek kullanıcı için yeterli)
# Postgres istersen: docker compose --profile postgres ... ve aşağıyı doldur
# DATABASE_TYPE=postgres
# DATABASE_HOST=postgres
# DATABASE_PORT=5432
# DATABASE_USERNAME=openwa
# DATABASE_PASSWORD=CHANGE_ME
# DATABASE_NAME=openwa

# --- Webhook → n8n ---
# Webhook URL'si .env'e değil, dashboard'da oturuma tanımlanır:
# Sessions -> (oturum) -> Webhook -> https://n8n.<domain>/webhook/openwa
